# MongoDB Connection
ENABLE_MONGODB=true
MONGODB_URI=mongodb://localhost:27017/safe-zone
# For Atlas (remote): MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/safe-zone

# Server Port
PORT=3001

# Demo Mode
ENABLE_DEMO_MODE=true

# Data Refresh Interval (milliseconds)
REFRESH_INTERVAL_MS=30000

# Air Alert Ukraine API (optional, for live data)
AIR_ALERT_PRIMARY_URL=https://alerts.com.ua/api/states
AIR_ALERT_FALLBACK_URL=
